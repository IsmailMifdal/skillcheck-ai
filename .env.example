# ─────────────────────────────────────────────────────────────
# SkillCheck AI — Variables d'environnement
# Copie ce fichier en `.env.local` et remplis les valeurs.
# ⚠️ Ne commite JAMAIS .env.local — il contient des secrets.
# ─────────────────────────────────────────────────────────────

# ── OpenAI (SERVEUR UNIQUEMENT — jamais exposé au client) ──
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Modèles (surchargeables). Par défaut : 4o pour le complexe, 4o-mini pour le simple.
OPENAI_MODEL_COMPLEX=gpt-4o
OPENAI_MODEL_SIMPLE=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Supabase ──
# URL et clé anon sont publiques (préfixe NEXT_PUBLIC_) — utilisées côté client.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Clé service_role — SECRÈTE, serveur uniquement. Contourne les RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
